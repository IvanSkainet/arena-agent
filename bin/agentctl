#!/usr/bin/env python3
"""
Arena Agent CLI (agentctl) v2.0 — Unified Bridge compatible.

Works TWO ways:
  1. Direct CLI:  agentctl.py sys status
  2. Via Bridge:  Uses /v1/* HTTP API when BRIDGE_URL is set

Cross-platform: Windows, Linux, macOS.
"""
from __future__ import annotations
import sys, os, subprocess, shutil, json, time, platform
from pathlib import Path

VERSION = "2.0.0"

ROOT = Path(os.environ.get("ARENA_AGENT_HOME", str(Path.home() / "arena-bridge"))).expanduser()
BRIDGE_URL = os.environ.get("ARENA_BRIDGE_URL", "http://127.0.0.1:8765")
BRIDGE_TOKEN = ""
BIN = ROOT / "bin"
SCRIPTS = ROOT / "scripts"

# Load token from file
_token_path = Path.home() / "arena-bridge" / "token.txt"
if _token_path.exists():
    BRIDGE_TOKEN = _token_path.read_text().strip().split("\n")[0].strip()

# ─── Bridge HTTP API helpers ──────────────────────────────────────────────

def _bridge_get(path: str, token: bool = True):
    """GET from bridge API."""
    import urllib.request, ssl
    url = f"{BRIDGE_URL}{path}"
    req = urllib.request.Request(url)
    if token and BRIDGE_TOKEN:
        req.add_header("Authorization", f"Bearer {BRIDGE_TOKEN}")
    ctx = ssl.create_default_context() if url.startswith("https") else None
    if ctx:
        ctx.check_hostname = False
        ctx.verify_mode = 0
    kw = {"timeout": 15}
    if ctx:
        kw["context"] = ctx
    resp = urllib.request.urlopen(req, **kw)
    return json.loads(resp.read().decode())

def _bridge_post(path: str, data: dict, token: bool = True):
    """POST to bridge API."""
    import urllib.request, ssl
    url = f"{BRIDGE_URL}{path}"
    body = json.dumps(data).encode()
    req = urllib.request.Request(url, data=body, method="POST")
    if token and BRIDGE_TOKEN:
        req.add_header("Authorization", f"Bearer {BRIDGE_TOKEN}")
    req.add_header("Content-Type", "application/json")
    ctx = ssl.create_default_context() if url.startswith("https") else None
    if ctx:
        ctx.check_hostname = False
        ctx.verify_mode = 0
    kw = {"timeout": 20}
    if ctx:
        kw["context"] = ctx
    resp = urllib.request.urlopen(req, **kw)
    return json.loads(resp.read().decode())

def _exec(cmd: str, timeout: int = 30) -> dict:
    """Execute command via bridge /v1/exec."""
    return _bridge_post("/v1/exec", {"cmd": cmd, "timeout": timeout})

# ─── Helpers ───────────────────────────────────────────────────────────────

def run_script(script: str, args: list = None):
    """Run a Python script from scripts/ directory."""
    py = sys.executable or "python3"
    cmd = [py, str(SCRIPTS / script)] + (args or [])
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)

def run_bin(tool: str, args: list = None):
    """Run a bin tool."""
    py = sys.executable or "python3"
    tool_path = BIN / tool
    if tool_path.suffix == ".py":
        cmd = [py, str(tool_path)] + (args or [])
    else:
        cmd = [str(tool_path)] + (args or [])
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)

# ─── Namespace: sys ───────────────────────────────────────────────────────

def sys_status(args):
    """System status via bridge API."""
    try:
        health = _bridge_get("/health", token=False)
        info = _bridge_get("/v1/sysinfo")
        svc = _bridge_get("/v1/sys/svc")
        funnel = _bridge_get("/v1/sys/funnel")
        
        print(f"{'='*50}")
        print(f"Arena Unified Bridge v{health.get('version','?')}")
        print(f"{'='*50}")
        print(f"  Host:     {health.get('host','?')}")
        print(f"  Platform: {health.get('platform','?')}")
        print(f"  Profile:  {health.get('profile','?')}")
        print(f"  Root:     {health.get('root','?')}")
        print(f"  CPU:      {info.get('cpu_cores','?')} cores")
        print(f"  RAM:      {info.get('mem_total_mb',0)} MB total, {info.get('mem_avail_mb',0)} MB avail")
        print(f"  Disk:     {info.get('disk_free_gb',0)} GB free / {info.get('disk_total_gb',0)} GB total")
        print(f"  Uptime:   {health.get('uptime_seconds',0):.0f}s")
        
        # Funnel
        ts = funnel.get("tailscale", {})
        if ts.get("connected"):
            print(f"  Tailscale: connected ({ts.get('status','')[:50]})")
        fn = funnel.get("funnel", {})
        if fn.get("active") is not False:
            print(f"  Funnel:   {fn.get('status','?')[:80]}")
        print(f"{'='*50}")
    except Exception as e:
        print(f"Error contacting bridge: {e}")
        sys.exit(1)

def sys_doctor(args):
    """Run diagnostics via bridge /v1/doctor."""
    try:
        d = _bridge_get("/v1/doctor")
        print(f"\n{'='*50}")
        print(f"Doctor: {d.get('passed',0)}/{d.get('total',0)} checks passed")
        print(f"{'='*50}")
        for c in d.get("checks", []):
            icon = "✅" if c["ok"] else "❌"
            print(f"  {icon} {c['name']}: {c.get('detail','')}")
        print()
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

def sys_beep(args):
    """Play sound via bridge /v1/beep."""
    btype = args[0] if args else "success"
    try:
        r = _bridge_post("/v1/beep", {"type": btype})
        print(f"Beep: {r.get('type','?')} freq={r.get('frequency','?')}Hz dur={r.get('duration','?')}ms")
    except Exception as e:
        print(f"Error: {e}")

def sys_svc(args):
    """Show services status."""
    try:
        r = _bridge_get("/v1/sys/svc")
        print(json.dumps(r, indent=2, ensure_ascii=False))
    except Exception as e:
        print(f"Error: {e}")

def sys_funnel(args):
    """Show Tailscale Funnel status."""
    try:
        r = _bridge_get("/v1/sys/funnel")
        ts = r.get("tailscale", {})
        fn = r.get("funnel", {})
        print("Tailscale:", ts.get("status", "unknown")[:200])
        print("Funnel:", fn.get("status", "unknown")[:200])
    except Exception as e:
        print(f"Error: {e}")

def sys_fix(args):
    """Run auto-fix via bridge."""
    print("Auto-fix not yet implemented in unified bridge. Use: agentctl sys doctor")

# ─── Namespace: mem ───────────────────────────────────────────────────────

def mem_set(args):
    if len(args) < 2:
        print("Usage: agentctl mem set KEY VALUE [--tags tag1 tag2]")
        sys.exit(2)
    key, value = args[0], args[1]
    tags = []
    if "--tags" in args:
        ti = args.index("--tags")
        tags = args[ti+1:]
    try:
        r = _bridge_post("/v1/memory", {"action": "set", "key": key, "value": value, "tags": tags})
        print(f"{'OK' if r.get('ok') else 'FAIL'}: {r}")
    except Exception as e:
        print(f"Error: {e}")

def mem_get(args):
    # "mem get all" → list everything; "mem get KEY" → search by key
    if args and args[0].lower() == "all":
        q = ""
    else:
        q = args[0] if args else ""
    try:
        r = _bridge_get(f"/v1/memory?q={q}")
        facts = r.get("facts", [])
        print(f"Facts ({r.get('count',0)}):")
        for f in facts:
            print(f"  {f.get('key','?')}: {str(f.get('value',''))[:80]}")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: recall ────────────────────────────────────────────────────

def recall_search(args):
    q = args[0] if args else ""
    try:
        r = _bridge_get(f"/v1/recall?q={q}")
        results = r.get("results", [])
        print(f"Recall ({r.get('count',0)}):")
        for item in results:
            print(f"  [{item.get('score',0):.2f}] {item.get('key','?')}: {str(item.get('value',''))[:80]}")
    except Exception as e:
        print(f"Error: {e}")

def recall_digest(args):
    try:
        r = _bridge_get("/v1/recall/digest")
        print(r.get("digest", json.dumps(r, indent=2, ensure_ascii=False)))
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: browser ───────────────────────────────────────────────────

def browser_search(args):
    q = " ".join(args) if args else "test"
    try:
        r = _bridge_get(f"/v1/browser/search?q={q}")
        for res in r.get("results", []):
            print(f"  {res.get('title','?')}")
            print(f"    {res.get('url','')}")
            print(f"    {res.get('snippet','')[:100]}")
            print()
    except Exception as e:
        print(f"Error: {e}")

def browser_read(args):
    url = args[0] if args else "https://example.com"
    try:
        r = _bridge_get(f"/v1/browser/read?url={url}")
        print(r.get("text", r.get("content", json.dumps(r, indent=2, ensure_ascii=False)[:500])))
    except Exception as e:
        print(f"Error: {e}")

def browser_dump(args):
    url = args[0] if args else "https://example.com"
    try:
        r = _bridge_get(f"/v1/browser/dump?url={url}")
        print(r.get("text", json.dumps(r, indent=2, ensure_ascii=False)[:500]))
    except Exception as e:
        print(f"Error: {e}")

def browser_head(args):
    url = args[0] if args else "https://example.com"
    try:
        r = _bridge_get(f"/v1/browser/head?url={url}")
        print(json.dumps(r, indent=2, ensure_ascii=False))
    except Exception as e:
        print(f"Error: {e}")

def browser_shot(args):
    """Screenshot via headless Chrome/Edge."""
    url = args[0] if args else "https://example.com"
    shots_dir = ROOT / "reports" / "shots"
    shots_dir.mkdir(parents=True, exist_ok=True)
    png = str(shots_dir / f"shot-{int(time.time())}.png")
    
    candidates = []
    if platform.system() == "Windows":
        candidates = [
            os.path.expanduser(r"~\AppData\Local\Google\Chrome\Application\chrome.exe"),
            r"C:\Program Files\Google\Chrome\Application\chrome.exe",
            r"C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe",
            r"C:\Program Files (x86)\Google\Chrome\Application\chrome.exe",
            r"C:\Program Files\LibreWolf\librewolf.exe",
            r"C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe",
        ]
    else:
        candidates = ["chromium", "chrome", "google-chrome", "google-chrome-stable",
                       "librewolf", "brave", "brave-browser", "firefox"]
    
    exe = None
    for c in candidates:
        if os.path.isfile(c) or shutil.which(c):
            exe = c
            break
    
    if not exe:
        print("No browser found for screenshot")
        sys.exit(1)
    
    import tempfile
    ud = os.path.join(tempfile.gettempdir(), f"cr-{os.getpid()}")
    cmd = [exe, "--headless=new", "--no-sandbox", "--disable-gpu",
           f"--user-data-dir={ud}", "--window-size=1366,768",
           f"--screenshot={png}", url]
    
    try:
        subprocess.run(cmd, capture_output=True, timeout=30)
        if os.path.exists(png):
            sz = os.path.getsize(png)
            print(f"Screenshot saved: {png} ({sz//1024}KB)")
        else:
            print("Screenshot failed")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: task ──────────────────────────────────────────────────────

def task_list(args):
    try:
        r = _bridge_get("/v1/tasks")
        tasks = r.get("tasks", [])
        print(f"Tasks ({r.get('count',0)}):")
        for t in tasks:
            print(f"  [{t.get('state','?')}] {t.get('id','?')} {t.get('cmd','')[:60]}")
    except Exception as e:
        print(f"Error: {e}")

def task_submit(args):
    if not args:
        print("Usage: agentctl task submit CMD")
        sys.exit(2)
    cmd = " ".join(args)
    try:
        r = _bridge_post("/v1/tasks", {"cmd": cmd})
        print(f"Submitted: {r.get('id','?')} {r.get('state','?')}")
    except Exception as e:
        print(f"Error: {e}")

def task_clean(args):
    try:
        r = _bridge_post("/v1/tasks/clean", {})
        print(f"Cleaned: {r}")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: skill ─────────────────────────────────────────────────────

def skill_list(args):
    try:
        r = _bridge_get("/v1/skills")
        skills = r.get("skills", [])
        print(f"Skills ({r.get('count',0)}):")
        for s in skills:
            desc = s.get("description", "")[:50]
            print(f"  {s.get('name','?'):40s} {desc}")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: audit ─────────────────────────────────────────────────────

def audit_stats(args):
    try:
        r = _bridge_get("/v1/audit/stats")
        print(f"Total events: {r.get('total',0)}")
        for k, v in r.get("by_type", {}).items():
            print(f"  {k}: {v}")
    except Exception as e:
        print(f"Error: {e}")

def audit_tail(args):
    n = args[0] if args else "10"
    try:
        r = _bridge_get(f"/v1/audit?lines={n}")
        lines = r.get("lines", [])
        for l in lines[-int(n):]:
            print(l)
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: backup ────────────────────────────────────────────────────

def backup_run(args):
    paths = args if args else [str(ROOT)]
    try:
        r = _bridge_post("/v1/backup", {"paths": paths})
        print(f"Backup: {r.get('ok')} files={r.get('file_count',0)} size={r.get('size',0)//1024}KB")
        print(f"Path: {r.get('backup_path','')}")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: mission ───────────────────────────────────────────────────

def mission_list(args):
    try:
        r = _bridge_get("/v1/missions")
        missions = r.get("missions", [])
        print(f"Missions ({r.get('count',0)}):")
        for m in missions:
            print(f"  {m.get('name','?')}")
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: report ────────────────────────────────────────────────────

def report_list(args):
    try:
        r = _bridge_get("/v1/reports")
        print(json.dumps(r, indent=2, ensure_ascii=False)[:500])
    except Exception as e:
        print(f"Error: {e}")

# ─── Namespace: sub ───────────────────────────────────────────────────────

def sub_spawn(args):
    run_bin("subagent.py", ["spawn"] + args)

def sub_list(args):
    run_bin("subagent.py", ["list"])

# ─── Namespace: mcp ───────────────────────────────────────────────────────

def mcp_install(args):
    run_bin("mcp_marketplace.py", ["install"] + args)

def mcp_list(args):
    run_bin("mcp_marketplace.py", ["list"])

# ─── Namespace: commands ──────────────────────────────────────────────────

def commands(args):
    print(f"""Arena Agent CLI v{VERSION} — Command Reference

Namespaces:
  sys     status|doctor|beep|svc|funnel|fix     System diagnostics
  mem     set|get                                Memory facts
  recall  search|digest                          TF-scored recall
  browser search|read|dump|head|shot             Browser tools
  task    list|submit|clean                      Task queue
  skill   list                                   Skills
  audit   stats|tail                             Audit log
  backup  run                                    Backups
  mission list                                   Missions
  report  list                                   Reports
  sub     spawn|list                             Subagents
  mcp     install|list                           MCP servers
  commands                                       This help

Usage: agentctl [namespace] [command] [args...]
Environment:
  ARENA_AGENT_HOME    Agent root directory (default: ~/arena-bridge)
  ARENA_BRIDGE_URL    Bridge URL (default: http://127.0.0.1:8765)
""")

# ─── Main dispatcher ──────────────────────────────────────────────────────

DISPATCH = {
    "sys": {
        "status": sys_status, "doctor": sys_doctor, "beep": sys_beep,
        "svc": sys_svc, "funnel": sys_funnel, "fix": sys_fix,
    },
    "mem": {"set": mem_set, "get": mem_get},
    "recall": {"search": recall_search, "digest": recall_digest},
    "browser": {
        "search": browser_search, "py-search": browser_search,
        "read": browser_read, "py-read": browser_read,
        "dump": browser_dump, "py-dump": browser_dump,
        "head": browser_head, "py-head": browser_head,
        "shot": browser_shot, "sd-shot": browser_shot,
    },
    "task": {"list": task_list, "ls": task_list, "submit": task_submit, "clean": task_clean},
    "skill": {"list": skill_list, "ls": skill_list},
    "audit": {"stats": audit_stats, "tail": audit_tail},
    "backup": {"run": backup_run},
    "mission": {"list": mission_list, "ls": mission_list},
    "report": {"list": report_list, "ls": report_list},
    "sub": {"spawn": sub_spawn, "list": sub_list},
    "mcp": {"install": mcp_install, "list": mcp_list},
    "commands": {"": commands},
}

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("h", "help", "--help", "-h"):
        commands([])
        sys.exit(0)
    
    ns = sys.argv[1].lower()
    args = sys.argv[2:]
    
    ns_map = DISPATCH.get(ns)
    if not ns_map:
        print(f"Unknown namespace: {ns}")
        print("Run: agentctl commands")
        sys.exit(2)
    
    sub = args[0].lower() if args else ""
    func = ns_map.get(sub)
    if not func:
        # Try first function in namespace as default
        if ns_map:
            func = list(ns_map.values())[0]
            args = [sub] + args[1:]  # keep sub as arg
        else:
            print(f"Unknown command: {ns} {sub}")
            sys.exit(2)
    
    try:
        func(args[1:] if sub else args)
    except SystemExit:
        raise
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
