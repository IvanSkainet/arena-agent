{
  "manifest_version": 3,
  "name": "Arena Chat Bridge MVP",
  "version": "0.10.5",
  "description": "Detects arena-tool blocks in web chats and executes them through a local Arena Unified Bridge.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://grok.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*",
    "https://openrouter.ai/*",
    "https://chat.deepseek.com/*",
    "https://t3.chat/*",
    "https://github.com/copilot/*",
    "https://chat.mistral.ai/*",
    "https://kimi.com/*",
    "https://chat.qwen.ai/*",
    "https://chat.z.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "adapter_sites.js",
        "parser.js",
        "adapters.js",
        "settings.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
